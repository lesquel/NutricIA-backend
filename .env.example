# ──────────────────────────────────────────────
# NutricIA Backend — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
DEBUG=true

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutricia


# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── AI Provider ──────────────────────────────
# Supported: gemini | openai | anthropic | deepseek | groq | mistral | mock
AI_PROVIDER=gemini

# Model to use (leave empty for provider default).
# Defaults: gemini-2.0-flash | gpt-4o | claude-sonnet-4-20250514
#           deepseek-chat | llama-4-scout-17b-16e-instruct | pixtral-large-latest
AI_MODEL=

# API keys — only the one matching your provider is required
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
