# ──────────────────────────────────────────────
# NutricIA Backend — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
DEBUG=true

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutricia

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── AI Provider ──────────────────────────────
# Supported: gemini | openai | anthropic | deepseek | groq | mistral
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
