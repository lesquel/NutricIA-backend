# =====================================================
# NutricIA Backend - Environment Variables
# Copy to .env and fill in your values
# =====================================================

# ---- App -------------------------------------------
DEBUG=true

# ---- Database --------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutricia

# ---- CORS ------------------------------------------
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ---- JWT -------------------------------------------
JWT_SECRET=change-me-in-production

# ---- AI Provider -----------------------------------
# Supported: groq | gemini | openai | anthropic | deepseek | mistral | mock
# Groq is the recommended primary provider (fast + free tier).
AI_PROVIDER=groq

# Model override (leave empty for provider default).
# Defaults:
#   groq      -> meta-llama/llama-4-scout-17b-16e-instruct
#   gemini    -> gemini-2.0-flash
#   openai    -> gpt-4o
#   anthropic -> claude-sonnet-4-20250514
#   deepseek  -> deepseek-chat
#   mistral   -> pixtral-large-latest
AI_MODEL=

# API keys - only the one matching your provider is strictly required.
# NOTE: Groq does NOT provide embeddings, so RAG (food catalog, meal
# embeddings) still requires GOOGLE_API_KEY or OPENAI_API_KEY.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# ---- OAuth -----------------------------------------
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
